GIN_MODE=debug
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Local DB (individual vars) — used when DATABASE_URL is not set
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=myuser
DB_PASSWORD=mysecretpassword
DB_NAME=mydatabase

# PaaS single DSN — set this on Railway/Render; takes precedence over DB_* vars
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require

# Error tracking — leave empty to disable Sentry locally
# SENTRY_DSN=https://...@sentry.io/...
